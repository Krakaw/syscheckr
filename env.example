# Copy to .env (auto-loaded) or secrets.env (pass with --env-file), then fill in.
# chmod 600 and keep it out of git. Real environment variables override these.

# Slack incoming webhook URL for the `slack` reporter.
SLACK_WEBHOOK_URL=

# Generic webhook reporter destination + optional HMAC signing secret.
OPS_WEBHOOK_URL=
OPS_WEBHOOK_SECRET=

# Linear issue creation: API key and the team UUID to file issues under.
LINEAR_API_KEY=
LINEAR_TEAM_ID=
